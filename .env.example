# Database Connection
# Get this from your Supabase project settings
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Site URL (Optional for local dev, Required for Vercel deployment)
# For local development, you can leave this commented out or set to http://localhost:4321
# For Vercel deployment, set this to your production domain
# Examples:
# - PUBLIC_SITE_URL="https://your-project.vercel.app"
# - PUBLIC_SITE_URL="https://your-custom-domain.com"
PUBLIC_SITE_URL=""

# Note: Astro requires public environment variables to start with PUBLIC_
# This makes them available in both server and client code
