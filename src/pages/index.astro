---
import Layout from "../layouts/Layout.astro";
import { PollCreatorWithToast } from "../components/PollCreatorWithToast";
import { ThemeToggle } from "../components/ThemeToggle";
---

<Layout title="PulseVote - Create Real-Time Polls">
    <ThemeToggle client:load />
    <div class="space-y-12">
        <header class="text-center space-y-6 animate-slide-up">
            <h1
                class="text-6xl md:text-8xl font-bold tracking-tight bg-gradient-to-br from-foreground via-foreground to-muted-foreground bg-clip-text text-transparent leading-[1.1]"
            >
                PulseVote
            </h1>
            <p
                class="text-xl md:text-2xl text-muted-foreground max-w-2xl mx-auto leading-relaxed font-light"
            >
                Create polls in seconds. Share instantly. Watch results update
                live.
            </p>
            <div
                class="flex flex-wrap justify-center gap-4 text-sm text-muted-foreground pt-4"
            >
                <div class="flex items-center gap-2">
                    <svg
                        class="h-5 w-5 text-primary"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                    <span>Instant creation</span>
                </div>
                <div class="flex items-center gap-2">
                    <svg
                        class="h-5 w-5 text-secondary"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
                        ></path>
                    </svg>
                    <span>Easy sharing</span>
                </div>
                <div class="flex items-center gap-2">
                    <svg
                        class="h-5 w-5 text-accent"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
                        ></path>
                    </svg>
                    <span>Live updates</span>
                </div>
            </div>
        </header>

        <div class="animate-slide-up delay-200">
            <PollCreatorWithToast client:load />
        </div>
    </div>
</Layout>
